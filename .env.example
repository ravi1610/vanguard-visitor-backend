# ─── Database ────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vanguard_visitor"

# ─── JWT ─────────────────────────────────────────────────────────
# Use a long random string in production
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ──────────────────────────────────────────────────────
PORT=3000

# ─── CORS ────────────────────────────────────────────────────────
# Comma-separated origins. Defaults to localhost:5173 if not set.
# Local:
CORS_ORIGINS="http://localhost:5173,http://localhost:4173"
# Dev / Production:
# CORS_ORIGINS="https://dev.vanguardvisitor.com,https://vanguardvisitor.com"

# ─── App URL (used for QR code URLs) ─────────────────────────────
APP_URL="http://localhost:5173"
# Dev / Production:
# APP_URL="https://dev.vanguardvisitor.com"

# ─── Settings Encryption (encrypts API keys stored in System Settings) ─
# Must be 32+ characters. Required in production.
# SETTINGS_ENCRYPTION_KEY="your-32-char-encryption-key-here"

# ─── Redis (optional — enables async reports & Redis cache) ──────
# Omit or leave empty to use in-memory cache and sync reports.
# REDIS_URL="redis://localhost:6379"

# ─── Superadmin Seeding (optional — for first-time setup) ────────
# SEED_SUPERADMIN=true
# SUPERADMIN_EMAIL=admin@vanguardvisitor.com
# SUPERADMIN_PASSWORD=SuperAdmin123!
# SUPERADMIN_FIRST_NAME=Super
# SUPERADMIN_LAST_NAME=Admin
# SUPERADMIN_TENANT_SLUG=sunset-bay

# ─── Database Seeding (Docker only) ──────────────────────────────
# RUN_SEED=true

# ─── Dummy data (staff, visitors, visits, etc.) ───────────────────
# Set to true to seed dummy data for development. Ignored in production.
# SEED_DUMMY=true
# Per-entity seed counts when SEED_DUMMY=true (omit to use defaults).
# UNITS_SEED_COUNT=200
# RESIDENTS_SEED_COUNT=10
# MAINTENANCE_SEED_COUNT=10
# VISITORS_SEED_COUNT=100
# VISITS_SEED_COUNT=100
# VEHICLES_SEED_COUNT=50
# STAFF_SEED_COUNT=20
# PROJECTS_SEED_COUNT=10
# TASKS_SEED_COUNT=30
# CALENDAR_EVENTS_SEED_COUNT=25
# DOCUMENTS_SEED_COUNT=500
# COMPLIANCE_SEED_COUNT=20
# VENDORS_SEED_COUNT=15
# SPACES_SEED_COUNT=30
# VIOLATIONS_SEED_COUNT=20
# PACKAGES_SEED_COUNT=50
# BOLOS_SEED_COUNT=10
# EMERGENCY_CONTACTS_SEED_COUNT=15
# PETS_SEED_COUNT=10
